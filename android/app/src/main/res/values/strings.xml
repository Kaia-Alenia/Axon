    <string name="guide_title">Connection Guide</string>
    <string name="guide_wifi_title">Wi-Fi Connection</string>
    <string name="guide_wifi_step">1. Connect both your phone and PC to the same Wi-Fi network.\n2. Launch the Axon server executable on your PC.\n3. Scan the QR code shown in the PC terminal or type the IP manually in the app.</string>
    <string name="guide_usb_title">USB Connection (ADB)</string>
    <string name="guide_usb_step">1. Connect your phone to the PC using a USB cable.\n2. Enable \'USB Debugging\' in your phone\'s Developer Options.\n3. Run the Axon server and click \'Connect via USB\' in the app.</string>
    <string name="guide_bt_title">Bluetooth Connection</string>
    <string name="guide_bt_step">1. Pair your phone with your PC in the system Bluetooth settings.\n2. Select Bluetooth mode in the app.\n3. Choose your PC from the list of paired devices to connect.</string>
